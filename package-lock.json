    </div>

    <!-- Collection Section -->
    <section id="collection" class="py-24 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
        <div class="text-center mb-16">
            <h2 class="text-4xl md:text-5xl font-bold mb-4">Latest Drops</h2>
