            <span class="text-purple-400">•</span>
            <span>HOLOGRAPHIC</span>
            <span class="text-purple-400">•</span>
            <span>PREMIUM VINYL</span>
            <span class="text-purple-400">•</span>
            <span>WATERPROOF</span>
            <span class="text-purple-400">•</span>
            <span>UV RESISTANT</span>
            <span class="text-purple-400">•</span>
            <span>MATTE FINISH</span>
            <span class="text-purple-400">•</span>
            <span>HOLOGRAPHIC</span>
