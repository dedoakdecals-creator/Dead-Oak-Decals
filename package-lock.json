                    </button>
                </div>
                <div class="flex items-center gap-4 pt-4">
                    <div class="flex -space-x-2">
                        <div class="w-10 h-10 rounded-full bg-gray-600 border-2 border-black flex items-center justify-center text-xs">JD</div>
                        <div class="w-10 h-10 rounded-full bg-gray-500 border-2 border-black flex items-center justify-center text-xs">MK</div>
                        <div class="w-10 h-10 rounded-full bg-gray-400 border-2 border-black flex items-center justify-center text-xs">+2k</div>
                    </div>
                    <p class="text-sm text-gray-400">Trusted by 2,000+ creators</p>
                </div>
            </div>
            <div class="relative">
                <div class="relative z-10 grid grid-cols-2 gap-4 rotate-3 hover:rotate-0 transition-transform duration-700">
                    <div class="space-y-4 mt-12">
                        <div class="bg-gradient-to-br from-purple-500 to-blue-500 p-1 rounded-2xl transform hover:-translate-y-2 transition-transform duration-300">
                            <div class="bg-gray-900 rounded-2xl p-4 h-48 flex items-center justify-center">
                                <i data-lucide="ghost" class="w-24 h-24 text-white opacity-80"></i>
                            </div>
                        </div>
                        <div class="bg-gradient-to-br from-pink-500 to-orange-500 p-1 rounded-2xl transform hover:-translate-y-2 transition-transform duration-300">
                            <div class="bg-gray-900 rounded-2xl p-4 h-64 flex items-center justify-center">
                                <i data-lucide="flame" class="w-32 h-32 text-white opacity-80"></i>
                            </div>
                        </div>
                    </div>
                    <div class="space-y-4">
                        <div class="bg-gradient-to-br from-green-400 to-cyan-500 p-1 rounded-2xl transform hover:-translate-y-2 transition-transform duration-300">
                            <div class="bg-gray-900 rounded-2xl p-4 h-64 flex items-center justify-center">
                                <i data-lucide="gamepad-2" class="w-32 h-32 text-white opacity-80"></i>
                            </div>
                        </div>
                        <div class="bg-gradient-to-br from-yellow-400 to-red-500 p-1 rounded-2xl transform hover:-translate-y-2 transition-transform duration-300">
                            <div class="bg-gray-900 rounded-2xl p-4 h-48 flex items-center justify-center">
                                <i data-lucide="skull" class="w-24 h-24 text-white opacity-80"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Marquee -->
    <div class="border-y border-white/10 bg-black/50 py-4 marquee-container">
        <div class="marquee-content text-2xl font-bold text-gray-500 space-x-8">
            <span>WATERPROOF</span>
            <span class="text-purple-400">•</span>
            <span>UV RESISTANT</span>
            <span class="text-purple-400">•</span>
