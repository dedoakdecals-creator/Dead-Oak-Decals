    <!-- Cart Sidebar -->
    <div id="cart-overlay" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden opacity-0 transition-opacity" onclick="toggleCart()"></div>
    <div id="cart-sidebar" class="cart-sidebar fixed top-0 right-0 h-full w-full max-w-md bg-gray-900 border-l border-white/10 z-50 shadow-2xl flex flex-col">
        <div class="p-6 border-b border-white/10 flex justify-between items-center">
            <h2 class="text-2xl font-bold brand-font">Your Cart</h2>
            <button onclick="toggleCart()" class="p-2 hover:bg-white/10 rounded-full transition-colors">
                <i data-lucide="x" class="w-6 h-6"></i>
            </button>
        </div>
        
        <div id="cart-items" class="flex-1 overflow-y-auto p-6 space-y-4">
            <div class="text-center text-gray-500 mt-12">
                <i data-lucide="shopping-bag" class="w-16 h-16 mx-auto mb-4 opacity-20"></i>
                <p>Your cart is empty</p>
            </div>
        </div>

        <div class="p-6 border-t border-white/10 bg-black/20">
            <div class="flex justify-between mb-4 text-lg">
                <span class="text-gray-400">Subtotal</span>
                <span id="cart-total" class="font-bold">$0.00</span>
            </div>
            <button onclick="checkout()" class="w-full py-4 bg-gradient-to-r from-purple-500 to-blue-500 rounded-full font-bold hover:opacity-90 transition-opacity flex items-center justify-center gap-2">
                Checkout <i data-lucide="arrow-right" class="w-5 h-5"></i>
            </button>
            <p class="text-center text-xs text-gray-500 mt-4">Shipping calculated at checkout</p>
        </div>
    </div>

    <script>
        // Initialize Lucide icons
        lucide.createIcons();

        // Product Data
        const products = [
            { id: 1, name: "CAT, Construction MEME, JEEP, TRUCKS- Decal Sticker Vinyl Car Window Art", price: 6.99, category: "anime", image: "images/CAT, Construction MEME, JEEP, TRUCKS- Decal Sticker Vinyl Car Window Art.png", color: "from-purple-500 to-blue-500" },
            { id: 2, name: "GAS, GRASS, ASS NOBODY RIDES - TRUCK, SUV - Decal Sticker Vinyl Car Window Art", price: 6.99, category: "retro", image: "images/GAS, GRASS, ASS NOBODY RIDES - TRUCK, SUV - Decal Sticker Vinyl Car Window Art.png", color: "from-pink-500 to-orange-500" },
            { id: 3, name: "I'M SEXY AND I MOW IT, FUNNY JEEP, TRUCKS- Decal Sticker Vinyl Car Window Art", price: 6.99, category: "minimal", image: "images/I'M SEXY AND I MOW IT, FUNNY JEEP, TRUCKS- Decal Sticker Vinyl Car Window Art.png", color: "from-gray-400 to-gray-600" },
            { id: 4, name: "JUST THE TIP, 2nd AMENDMENT, JEEP, TRUCKS- Decal Sticker Vinyl Car Window Art", price: 6.99, category: "holographic", image: "images/JUST THE TIP, 2nd AMENDMENT, JEEP, TRUCKS- Decal Sticker Vinyl Car Window Art.png", color: "from-cyan-400 to-blue-500" },
            { id: 5, name: "Michael Myers Halloween FACE, JEEP, TRUCKS- Decal Sticker Vinyl Car Window Art", price: 6.99, category: "retro", image: "images/Michael Myers Halloween FACE, JEEP, TRUCKS- Decal Sticker Vinyl Car Window Art.png", color: "from-red-500 to-pink-500" },
            { id: 6, name: "Michael Myers, Halloween JEEP, TRUCKS- Decal Sticker Vinyl Car Window Art", price: 6.99, category: "anime", image: "images/Michael Myers, Halloween JEEP, TRUCKS- Decal Sticker Vinyl Car Window Art.png", color: "from-indigo-500 to-purple-500" },
            { id: 7, name: "PROBLEM, NO PROBLEM JEEP SUV CHEVROLET JDSM- Decal Sticker Vinyl Car Window", price: 6.99, category: "minimal", image: "images/PROBLEM, NO PROBLEM JEEP SUV CHEVROLET JDSM- Decal Sticker Vinyl Car Window.png", color: "from-green-400 to-emerald-600" },
            { id: 8, name: "SAVE A LOLLIPOP, JEEP, RACING, TRUCK, SUV - Decal Sticker Vinyl Car Window Art", price: 6.99, category: "holographic", image: "images/SAVE A LOLLIPOP, JEEP, RACING, TRUCK, SUV - Decal Sticker Vinyl Car Window Art.png", color: "from-yellow-400 to-red-500" }
        ];

        let cart = [];

        // Render Products
        function renderProducts(filter = 'all') {
            const grid = document.getElementById('product-grid');
            grid.innerHTML = '';
            
            const filtered = filter === 'all' ? products : products.filter(p => p.category === filter);
            
            filtered.forEach(product => {
                const card = document.createElement('div');
                card.className = 'sticker-card group relative bg-gray-900 rounded-3xl overflow-hidden border border-white/10';
                card.innerHTML = `
                    <div class="aspect-square bg-gradient-to-br ${product.color} p-1">
                        <div class="w-full h-full bg-gray-900 rounded-[20px] flex items-center justify-center relative overflow-hidden">
                            <div class="absolute inset-0 bg-gradient-to-br ${product.color} opacity-0 group-hover:opacity-20 transition-opacity"></div>
                            <img src="${product.image}" alt="${product.name}" class="w-full h-full object-contain relative z-10 glitch-hover p-4">
                        </div>
                    </div>
                    <div class="p-6">
                        <div class="flex justify-between items-start mb-2">
                            <div>
                                <h3 class="font-bold text-lg">${product.name}</h3>
                                <p class="text-sm text-gray-400 capitalize">${product.category}</p>
                            </div>
                            <span class="text-xl font-bold text-purple-400">$${product.price}</span>
                        </div>
                        <button onclick="addToCart(${product.id})" class="w-full mt-4 py-3 bg-white/5 hover:bg-white/10 border border-white/10 rounded-full font-medium transition-all flex items-center justify-center gap-2 group-hover:bg-purple-500 group-hover:border-purple-500">
                            <i data-lucide="plus" class="w-4 h-4"></i> Add to Cart
                        </button>
                    </div>
                `;
                grid.appendChild(card);
            });
            lucide.createIcons();
        }

        // Filter Function
        function filterProducts(category) {
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.remove('active');
                if(btn.textContent.toLowerCase() === category || (category === 'all' && btn.textContent === 'All')) {
                    btn.classList.add('active');
                }
            });
            renderProducts(category);
        }

        // Cart Functions
        function toggleCart() {
            const sidebar = document.getElementById('cart-sidebar');
            const overlay = document.getElementById('cart-overlay');
            
            if (sidebar.classList.contains('open')) {
                sidebar.classList.remove('open');
                overlay.classList.add('hidden');
                setTimeout(() => overlay.classList.remove('opacity-100'), 300);
            } else {
                sidebar.classList.add('open');
                overlay.classList.remove('hidden');
                setTimeout(() => overlay.classList.add('opacity-100'), 10);
            }
        }

        function addToCart(productId) {
            const product = products.find(p => p.id === productId);
            const existingItem = cart.find(item => item.id === productId);
            
            if (existingItem) {
                existingItem.quantity++;
            } else {
                cart.push({ ...product, quantity: 1 });
            }
            
            updateCart();
            
            // Open cart when adding item
            const sidebar = document.getElementById('cart-sidebar');
            if (!sidebar.classList.contains('open')) {
                toggleCart();
            }
        }

        function removeFromCart(productId) {
            cart = cart.filter(item => item.id !== productId);
            updateCart();
        }

        function updateQuantity(productId, change) {
            const item = cart.find(item => item.id === productId);
            if (item) {
                item.quantity += change;
                if (item.quantity <= 0) {
                    removeFromCart(productId);
                } else {
                    updateCart();
                }
            }
        }

        function updateCart() {
            const cartItems = document.getElementById('cart-items');
            const cartCount = document.getElementById('cart-count');
            const cartTotal = document.getElementById('cart-total');
            
            const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
            cartCount.textContent = totalItems;
            
            const total = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
            cartTotal.textContent = `$${total.toFixed(2)}`;
            
            if (cart.length === 0) {
                cartItems.innerHTML = `
                    <div class="text-center text-gray-500 mt-12">
                        <i data-lucide="shopping-bag" class="w-16 h-16 mx-auto mb-4 opacity-20"></i>
                        <p>Your cart is empty</p>
                    </div>
                `;
            } else {
                cartItems.innerHTML = cart.map(item => `
                    <div class="flex gap-4 bg-white/5 p-4 rounded-2xl border border-white/10">
                        <div class="w-20 h-20 bg-gradient-to-br ${item.color} rounded-xl flex items-center justify-center flex-shrink-0">
                            <img src="${item.image}" alt="${item.name}" class="w-8 h-8 object-contain">
                        </div>
                        <div class="flex-1">
                            <h4 class="font-bold">${item.name}</h4>
                            <p class="text-purple-400 font-medium">$${item.price}</p>
                            <div class="flex items-center gap-3 mt-2">
                                <button onclick="updateQuantity(${item.id}, -1)" class="quantity-btn w-6 h-6 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20">-</button>
                                <span class="text-sm font-medium w-4 text-center">${item.quantity}</span>
                                <button onclick="updateQuantity(${item.id}, 1)" class="quantity-btn w-6 h-6 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20">+</button>
                            </div>
                        </div>
                        <button onclick="removeFromCart(${item.id})" class="text-gray-500 hover:text-red-400 transition-colors">
                            <i data-lucide="trash-2" class="w-5 h-5"></i>
                        </button>
                    </div>
                `).join('');
            }
            
            lucide.createIcons();
        }

        // Checkout — redirect to Stripe
        async function checkout() {
            if (cart.length === 0) return;

            const btn = document.querySelector('#cart-sidebar button[onclick="checkout()"]');
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="animate-pulse">Redirecting to payment...</span>';

            try {
                const res = await fetch('/.netlify/functions/create-checkout-session', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        items: cart.map(item => ({
                            name: item.name,
                            price: item.price,
                            quantity: item.quantity
                        }))
                    })
                });

                const data = await res.json();

                if (!res.ok || !data.url) {
                    throw new Error(data.error || 'Failed to start checkout');
                }

                // Clear cart before redirecting
                cart = [];
                updateCart();

                window.location.href = data.url;
            } catch (err) {
                console.error('Checkout error:', err);
                btn.disabled = false;
                btn.innerHTML = originalText;
                lucide.createIcons();

                // Show error inline below the checkout button
                let errEl = document.getElementById('checkout-error');
                if (!errEl) {
                    errEl = document.createElement('p');
                    errEl.id = 'checkout-error';
                    errEl.className = 'text-center text-sm text-red-400 mt-3';
                    btn.parentNode.appendChild(errEl);
                }
                errEl.textContent = err.message || 'Something went wrong. Please try again.';
            }
        }

        // Initialize
        renderProducts();

        // Smooth scroll for navigation
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });
    </script>
</body>
</html>