                            </div>
                            <div>
                                <h4 class="font-bold mb-1">Upload Design</h4>
                                <p class="text-sm text-gray-400">PNG, SVG, or AI files accepted</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-4">
                            <div class="w-12 h-12 rounded-full bg-purple-500/20 flex items-center justify-center flex-shrink-0">
                                <i data-lucide="scissors" class="w-6 h-6 text-purple-400"></i>
