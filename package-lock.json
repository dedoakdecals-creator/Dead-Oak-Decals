                                <h4 class="font-bold mb-1">Fast Shipping</h4>
                                <p class="text-sm text-gray-400">Shipped within 48 hours</p>
                            </div>
                        </div>
                    </div>

                    <button class="mt-8 px-8 py-4 bg-gradient-to-r from-purple-500 to-blue-500 rounded-full font-bold hover:opacity-90 transition-opacity">
                        Start Custom Order
                    </button>
                </div>
                <div class="relative">
                    <div class="absolute inset-0 bg-gradient-to-r from-purple-500 to-blue-500 rounded-3xl blur-2xl opacity-20"></div>
                    <div class="relative bg-gray-900 border border-white/10 rounded-3xl p-8">
                        <div class="border-2 border-dashed border-white/20 rounded-2xl p-12 text-center hover:bg-white/5 transition-colors cursor-pointer group">
                            <i data-lucide="image-plus" class="w-16 h-16 mx-auto mb-4 text-gray-500 group-hover:text-purple-400 transition-colors"></i>
                            <p class="text-gray-400">Drop your design here or click to upload</p>
                            <p class="text-sm text-gray-600 mt-2">Max file size: 50MB</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features -->
    <section class="py-24 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
        <div class="grid md:grid-cols-3 gap-8">
            <div class="p-8 rounded-3xl bg-white/5 border border-white/10 hover:bg-white/10 transition-colors">
