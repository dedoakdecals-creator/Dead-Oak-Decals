            <button class="filter-btn px-6 py-2 rounded-full border border-white/20 text-sm font-medium transition-all hover:bg-white/5" onclick="filterProducts('anime')">Anime</button>
            <button class="filter-btn px-6 py-2 rounded-full border border-white/20 text-sm font-medium transition-all hover:bg-white/5" onclick="filterProducts('retro')">Retro</button>
            <button class="filter-btn px-6 py-2 rounded-full border border-white/20 text-sm font-medium transition-all hover:bg-white/5" onclick="filterProducts('minimal')">Minimal</button>
            <button class="filter-btn px-6 py-2 rounded-full border border-white/20 text-sm font-medium transition-all hover:bg-white/5" onclick="filterProducts('holographic')">Holographic</button>
        </div>

