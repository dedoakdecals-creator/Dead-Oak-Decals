    <!-- Custom Order Section -->
    <section id="custom" class="py-24 bg-white/5 border-y border-white/10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid md:grid-cols-2 gap-12 items-center">
                <div>
                    <h2 class="text-4xl font-bold mb-6">Create Your Own</h2>
                    <p class="text-gray-400 mb-8 text-lg">Have a design in mind? We can turn your artwork into high-quality vinyl decals. Perfect for brands, events, or personal projects.</p>
                    
                    <div class="space-y-4">
                        <div class="flex items-start gap-4">
                            <div class="w-12 h-12 rounded-full bg-purple-500/20 flex items-center justify-center flex-shrink-0">
